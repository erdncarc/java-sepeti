<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/homepage_courier_xml"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/courier_homepage_background">

    <LinearLayout
        android:id="@+id/id1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="20dp"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/courier_pp"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@drawable/circle_for_photo"
                android:clipToOutline="true"
                android:contentDescription="@null"
                android:src="@drawable/anonymous_image" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome"
                    android:textAppearance="@style/r_gray_18"
                    android:textColor="#616161" />

                <TextView
                    android:id="@+id/courier_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="User"
                    android:textAppearance="@style/r_black_18" />

                <TextView
                    android:id="@+id/courier_rate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignTop="@id/food_image"
                    android:layout_alignEnd="@+id/food_image"
                    android:drawableStart="@drawable/star_rate"
                    android:text="Rate"
                    android:textAppearance="@style/r_black_12"
                    android:textStyle="bold" />

            </LinearLayout>


        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Are you ready for ride?"
            android:textAppearance="@style/r_gray_18"
            android:textColor="#616161" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/id2"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:layout_gravity="center"
        android:layout_marginStart="30dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="30dp"
        android:background="@drawable/rectangle_fill"
        android:backgroundTint="@color/light_gray"
        app:layout_constraintTop_toBottomOf="@id/id1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/available"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/rectangle_fill"
                android:backgroundTint="@color/available_green"
                android:gravity="center"
                android:text="Available"
                android:textAppearance="@style/r_white_18"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/occupied"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/rectangle_fill"
                android:backgroundTint="@color/light_gray"
                android:gravity="center"
                android:text="Occupied"
                android:textAppearance="@style/r_black_18"
                android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>

    <TextView
        android:id="@+id/id3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:text="Current Packet"
        android:textAppearance="@style/r_black_20"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/id2" />

    <FrameLayout
        android:id="@+id/id4"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/id3">

        <include layout="@layout/courier_active_order" />
    </FrameLayout>

    <TextView
        android:id="@+id/id5"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:text="Registered Restourant"
        android:textAppearance="@style/r_black_20"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/id4" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_marginTop="10dp"
        android:layout_height="0dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="65dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/id5">

        <LinearLayout
            android:id="@+id/restaurants"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:padding="8dp"
            android:scrollbars="vertical">

        </LinearLayout>
    </ScrollView>

    <include layout="@layout/panel_courier" />

</androidx.constraintlayout.widget.ConstraintLayout>