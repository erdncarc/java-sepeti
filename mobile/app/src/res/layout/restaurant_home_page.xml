<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools">


    <ImageView
        android:id="@+id/top_bg"
        android:layout_width="430dp"
        android:layout_height="150dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:src="@drawable/top"

        android:contentDescription="@null"
        tools:ignore="MissingConstraints" />

    <ImageView
        android:id="@+id/nusret"
        android:layout_width="277dp"
        android:layout_height="128dp"
        android:layout_alignTop="@id/top_bg"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="16dp"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/nusret"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="MissingConstraints" />



    <RelativeLayout
        android:id="@+id/restaurant_info_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_marginHorizontal="16dp"
        android:layout_marginStart="1dp"
        app:layout_constraintTop_toBottomOf="@id/top_bg"
        android:layout_marginTop="0dp"
        android:background="@drawable/kirmizigradient"
        android:padding="16dp"
        tools:ignore="MissingConstraints">

        <!-- Restaurant Name -->
        <TextView
            android:id="@+id/restaurant_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/righteous"
            android:text="Nusr•Et Steak House"
            android:textColor="#000"
            android:textSize="22sp"
            android:textStyle="bold" />



        <!-- Ratings Row -->
        <LinearLayout
            android:id="@+id/ratings_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/restaurant_name"
            android:layout_alignParentStart="true"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <!-- Delivery -->
            <TextView
                style="@style/ratingTag"
                android:drawableStart="@drawable/ic_delivery"
                android:text="3.7" />

            <!-- Taste -->
            <TextView
                style="@style/ratingTag"
                android:layout_marginStart="8dp"
                android:drawableStart="@drawable/ic_taste"
                android:text="4.5" />

            <!-- Service -->
            <TextView
                style="@style/ratingTag"
                android:layout_marginStart="8dp"
                android:drawableStart="@drawable/star"
                android:text="4.1" />
        </LinearLayout>

        <!-- Distance -->
        <TextView
            android:id="@+id/distance_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/ratings_row"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/righteous"
            android:text="distance:"
            android:textColor="#000"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/distance_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/ratings_row"
            android:layout_marginStart="6dp"
            android:layout_marginTop="12dp"
            android:layout_toEndOf="@id/distance_label"
            android:fontFamily="@font/righteous"
            android:text="2.0 km"
            android:textColor="#000" />

        <!-- Open / Close time -->
        <!-- Saat -->
        <TextView
            android:id="@+id/time_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/ratings_row"
            android:layout_marginTop="12dp"
            android:layout_alignParentEnd="true"
            android:fontFamily="@font/righteous"
            android:text="11.00AM - 10.30PM"
            android:textColor="#000" />

        <!-- Label -->
        <TextView
            android:id="@+id/time_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/ratings_row"
            android:layout_marginTop="12dp"
            android:layout_toStartOf="@id/time_value"
            android:layout_marginEnd="6dp"
            android:fontFamily="@font/righteous"
            android:text="open/close time:"
            android:textColor="#000"
            android:textSize="14sp"
            android:textStyle="bold" />


        <!-- Open Tag -->
        <TextView
            android:id="@+id/open_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/time_value"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="8dp"
            android:background="@drawable/open_tag"
            android:fontFamily="@font/righteous"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:text="OPEN"
            android:textColor="#fff" />




    </RelativeLayout>


    <FrameLayout
        android:id="@+id/bottom_background"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginTop="0dp"
        android:background="#EB2A38"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
    <LinearLayout
        android:id="@+id/bottom_nav"
        android:layout_width="0dp"
        android:background="#EB2A38"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">


        <ImageView
            android:id="@+id/home_button"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:clickable="true"
            android:contentDescription="@null"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:padding="6dp"
            android:src="@drawable/home_icon"
            tools:ignore="ImageContrastCheck,SpeakableTextPresentCheck" />


        <Space
            android:layout_width="25dp"
            android:layout_height="0dp" />

        <ImageView
            android:id="@+id/history_button"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:clickable="true"
            android:contentDescription="@null"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:padding="6dp"
            android:src="@drawable/history"
            tools:ignore="ImageContrastCheck,SpeakableTextPresentCheck" />

        <Space
            android:layout_width="50dp"
            android:layout_height="0dp" />

        <ImageView
            android:id="@+id/calorie_button"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:clickable="true"
            android:contentDescription="@null"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:padding="6dp"
            android:src="@drawable/comments"
            tools:ignore="ImageContrastCheck,SpeakableTextPresentCheck" />

        <Space
            android:layout_width="25dp"
            android:layout_height="0dp" />

        <ImageView
            android:id="@+id/profile_button"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:contentDescription="@null"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:padding="6dp"
            android:src="@drawable/material"
            tools:ignore="ImageContrastCheck,SpeakableTextPresentCheck" />

    </LinearLayout>



    <FrameLayout
        android:id="@+id/basket_button"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:background="@drawable/basket_icon_red"
        android:clickable="true"
        android:clipToOutline="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:layout_marginBottom="30dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:ignore="SpeakableTextPresentCheck">

        <ImageView
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_gravity="center"
            android:contentDescription="@null"
            android:src="@drawable/basket_icon"
            tools:ignore="ImageContrastCheck" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/search_container"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="0dp"
        android:orientation="horizontal"
        android:background="@drawable/search_box_bg"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        app:layout_constraintTop_toBottomOf="@id/restaurant_info_card"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/search"
            android:contentDescription="Search" />

        <EditText
            android:id="@+id/search_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Search"
            android:background="@android:color/transparent"
            android:textColor="#000"
            android:textColorHint="#999999"
            android:paddingStart="8dp"
            android:textSize="16sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/add_filter_buttons"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="@id/search_container"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/add_button"
            android:layout_width="45dp"
            android:layout_height="48dp"
            android:layout_marginEnd="3dp"
            android:background="@drawable/round_red_button"
            android:padding="10dp"
            android:src="@drawable/plus"
            android:contentDescription="Add" />

        <ImageView
            android:id="@+id/filter_button"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/round_red_button"
            android:padding="10dp"
            android:src="@drawable/settings2"
            android:contentDescription="Filter" />
    </LinearLayout>
    <View
        android:id="@+id/icon_park_o"
        android:layout_width="17dp"
        android:layout_height="17dp"
        android:layout_marginStart="307dp"
        android:layout_marginTop="280dp"
        android:background="@drawable/comment_white"
        android:clipToOutline="true"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />





</androidx.constraintlayout.widget.ConstraintLayout>