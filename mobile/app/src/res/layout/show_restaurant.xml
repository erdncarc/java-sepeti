<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/shown_restaurant"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <include layout="@layout/back_button" />

    <ImageView
        android:id="@+id/restaurant_image"
        android:layout_width="wrap_content"
        android:layout_height="175dp"
        android:contentDescription="@null"
        android:src="@drawable/restaurant_1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="MissingConstraints" />

    <RelativeLayout
        android:id="@+id/restaurant_info_card"
        android:layout_width="wrap_content"
        android:layout_height="150dp"
        android:background="@drawable/show_restaurant_background"
        android:padding="15dp"
        app:layout_constraintTop_toBottomOf="@id/restaurant_image"
        tools:ignore="MissingConstraints,TextSizeCheck">

        <TextView
            android:id="@+id/restaurant_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Restaurant Name"
            android:textAppearance="@style/r_black_30"
            android:textStyle="bold"
            tools:ignore="HardcodedText" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_alignParentBottom="true"
            android:gravity="end"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/filter_icon"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@drawable/circle_for_photo"
                android:backgroundTint="@color/dark_green"
                android:clickable="true"
                android:clipToOutline="true"
                android:contentDescription="@null"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:padding="3dp"
                android:src="@drawable/filter_icon"
                tools:ignore="SpeakableTextPresentCheck,ImageContrastCheck" />

            <TextView
                android:id="@+id/open_status"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/rectangle_fill"
                android:backgroundTint="@color/green"
                android:padding="5dp"
                android:text="STATUS"
                android:textAppearance="@style/r_white_12"
                tools:ignore="HardcodedText,TextContrastCheck" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/ratings_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/restaurant_name"
            android:layout_marginTop="5dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/courier_rate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawablePadding="5dp"
                android:text="Courier"
                android:textAppearance="@style/r_black_14"
                app:drawableStartCompat="@drawable/courier_rate"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/restaurant_rate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:drawablePadding="5dp"
                android:text="Restaurant"
                android:textAppearance="@style/r_black_14"
                app:drawableStartCompat="@drawable/restaurant_rate"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/rate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:drawablePadding="5dp"
                android:text="Rate"
                android:textAppearance="@style/r_black_14"
                app:drawableStartCompat="@drawable/star_rate"
                tools:ignore="HardcodedText" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/infos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/ratings_row"
            android:layout_marginTop="5dp"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/infos2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginEnd="60dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/clock_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="50dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="open/close time:"
                        android:textAppearance="@style/r_black_14"
                        android:textStyle="bold"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:id="@+id/time_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="... - ..."
                        android:textAppearance="@style/r_black_14"
                        tools:ignore="HardcodedText" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/distance_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="distance:"
                        android:textAppearance="@style/r_black_14"
                        android:textStyle="bold"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:id="@+id/distance_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="... km"
                        android:textAppearance="@style/r_black_14"
                        tools:ignore="HardcodedText" />
                </LinearLayout>

            </LinearLayout>

            <TextView
                android:id="@+id/address"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="address"
                android:textAppearance="@style/r_black_14"
                tools:ignore="HardcodedText" />
        </LinearLayout>


    </RelativeLayout>

    <ScrollView
        android:id="@+id/food_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginBottom="65dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/restaurant_info_card">

        <GridLayout
            android:id="@+id/food_grid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:columnCount="2"
            android:orientation="horizontal"
            android:padding="15dp">

        </GridLayout>
    </ScrollView>

    <include layout="@layout/panel_customer" />

</androidx.constraintlayout.widget.ConstraintLayout>